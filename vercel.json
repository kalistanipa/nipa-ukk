{
    "functions": {
        "*.php": {
            "runtime": "vercel-php@0.6.2"
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*\\.php)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}